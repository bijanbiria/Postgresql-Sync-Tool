# ==========================================
# Local Database Configuration (Optional)
# ==========================================
# Uncomment and modify if your local PostgreSQL is not on localhost:5432
# or if you're using a different database user
LOCAL_DB_HOST="localhost"
LOCAL_DB_PORT="5432"
LOCAL_DB_USER="your_local_db_user"
LOCAL_DB_PASS="your_local_db_password"

# ==========================================
# Server Configuration Template
# ==========================================
# Replace SERVER_NAME with your actual server identifier (e.g., PRODUCTION, STAGING)
# Duplicate this block for each server you want to sync from

# SERVER_NAME_SSH_HOST="your.server.ip.address"
# SERVER_NAME_SSH_PORT="22"
# SERVER_NAME_SSH_USER="your_ssh_user"
# SERVER_NAME_SSH_KEY="/path/to/your/ssh/private/key"

# SERVER_NAME_DB_CONTAINER_NAME="postgresql_container_name"
# SERVER_NAME_DB_USER="database_user"
# SERVER_NAME_DB_PASS="database_password"

# ==========================================
# Database Lists (For Interactive Selection)
# ==========================================
# Define available databases for each server
# Separate multiple database names with spaces

# Remote databases available on the server
# SERVER_NAME_DATABASES="db1 db2 db3"

# Local database names to sync into (must match the count of remote databases)
# SERVER_NAME_LOCAL_DATABASES="local_db1 local_db2 local_db3"

# ==========================================
# Example Configuration
# ==========================================

# Server: Example Production
EXAMPLE_SSH_HOST="192.168.1.100"
EXAMPLE_SSH_PORT="22"
EXAMPLE_SSH_USER="ubuntu"
EXAMPLE_SSH_KEY="/home/user/.ssh/id_rsa"

EXAMPLE_DB_CONTAINER_NAME="postgresql"
EXAMPLE_DB_USER="db_user"
EXAMPLE_DB_PASS="secure_password_here"

EXAMPLE_DATABASES="production_db"
EXAMPLE_LOCAL_DATABASES="local_production_db"
